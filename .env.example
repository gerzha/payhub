# Copy to .env for local (non-compose) runs. When running via `docker compose`,
# these are already set as `environment:` blocks in docker-compose.yml.

PAYHUB_DATABASE_URL=postgresql+asyncpg://payhub:payhub@localhost:5432/payhub
PAYHUB_SQS_ENDPOINT_URL=http://localhost:4566
PAYHUB_INBOUND_QUEUE_NAME=payhub-inbound-webhooks
PAYHUB_OUTBOUND_QUEUE_NAME=payhub-outbound-status
PAYHUB_STRIPE_LIKE_SECRET=stripe_like_dev_secret
PAYHUB_PAYPAL_LIKE_SECRET=paypal_like_dev_secret
PAYHUB_MAX_PROVIDER_RETRIES=5
PAYHUB_RETRY_BACKOFF_SECONDS=1.0

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
